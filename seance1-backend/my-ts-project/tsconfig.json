{
 "compilerOptions": {
 "target": "ES2022", //version Javascript générée
 "module": "CommonJS",
 "rootDir": "./src", //Code Source
 "outDir": "./dist", //Code Compilé
 "strict": true, //active le typage strict (fortement recommandé)
 "noImplicitAny": true,
 "strictNullChecks": true, // null/undefined doivent être explicites
 "strictFunctionTypes": true,
 "noUnusedParameters": true, 
 }
}